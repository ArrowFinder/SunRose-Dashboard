# Copy to .env.production when using `npm run deploy` from your computer.
# Repo name must match GitHub exactly (case-sensitive).
VITE_BASE=/your-repo-name/

# Needed on the live site if you use Supabase email login (same as local .env).
# Or skip these here and use GitHub Actions secrets instead — see DEPLOY.md.
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
