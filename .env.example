# =============================================================================
# OPTIONAL: only if you use Supabase for email login (cloud accounts).
# If you skip this file, the app works offline with PIN login only.
#
# HOW TO FILL THIS IN:
# 1. Open https://supabase.com and sign in. Open your project.
# 2. Click the gear icon (bottom left) = "Project Settings".
# 3. Click "API" in the left sidebar.
# 4. You will see two things to copy:
#
#    "Project URL"  →  paste it after VITE_SUPABASE_URL= below
#                      (looks like https://abcdefgh.supabase.co)
#
#    "anon" "public" key under Project API keys
#                      →  paste it after VITE_SUPABASE_ANON_KEY= below
#                      (a very long string; use the one labeled "anon", NOT "service_role")
#
# 5. Save this file as ".env" in the same folder as package.json (not .env.example).
# 6. Restart "npm run dev" after saving.
#
# Why the weird names? The app is built with a tool called Vite. It only reads
# settings whose names start with VITE_. You don't need to memorize that—just
# copy the two lines exactly as shown.
# =============================================================================

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
